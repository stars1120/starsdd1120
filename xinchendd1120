<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Heart Particle Effect</title>
  <style>
    :root {
      color-scheme: dark;
      --cyan: #65f7ff;
      --pink: #ff3f9d;
      --rose: #ff6bb7;
      --white: #f8fbff;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      width: 100%;
      height: 100%;
      margin: 0;
      overflow: hidden;
      background: #02030a;
      font-family: "Microsoft JhengHei UI", system-ui, sans-serif;
    }

    canvas {
      display: block;
      width: 100vw;
      height: 100vh;
    }

    .vignette {
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% 45%, rgba(255, 63, 157, 0.13), transparent 28%),
        radial-gradient(circle at 50% 50%, transparent 35%, rgba(2, 3, 10, 0.36) 72%, rgba(0, 0, 0, 0.82) 100%);
      mix-blend-mode: screen;
    }

    .scanlines {
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.13;
      background-image: linear-gradient(rgba(255,255,255,0.12) 1px, transparent 1px);
      background-size: 100% 4px;
    }
  </style>
</head>
<body>
  <canvas id="scene" aria-label="星空背景中的科幻愛心粒子特效"></canvas>
  <div class="vignette"></div>
  <div class="scanlines"></div>

  <script>
    const canvas = document.getElementById("scene");
    const ctx = canvas.getContext("2d", { alpha: false });

    const pointer = { x: 0, y: 0, active: false };
    const heartParticles = [];
    const stars = [];
    const comets = [];
    const sparks = [];

    let width = 0;
    let height = 0;
    let dpr = 1;
    let heartTargets = [];
    let lastTime = performance.now();

    const TAU = Math.PI * 2;
    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
    const random = (min, max) => min + Math.random() * (max - min);

    function resize() {
      dpr = clamp(window.devicePixelRatio || 1, 1, 2);
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      rebuildScene();
    }

    function heartPoint(t, scale) {
      const x = 16 * Math.pow(Math.sin(t), 3);
      const y = 13 * Math.cos(t) - 5 * Math.cos(2 * t) - 2 * Math.cos(3 * t) - Math.cos(4 * t);
      return { x: x * scale, y: -y * scale };
    }

    function buildHeartTargets() {
      const scale = Math.min(width, height) / 46;
      const centerX = width / 2;
      const centerY = height / 2 + Math.min(height * 0.045, 34);
      const targets = [];

      for (let i = 0; i < 520; i += 1) {
        const t = random(0, TAU);
        const p = heartPoint(t, scale);
        const fill = Math.sqrt(Math.random());
        targets.push({
          x: centerX + p.x * fill + random(-2, 2),
          y: centerY + p.y * fill + random(-2, 2),
          phase: random(0, TAU),
          layer: random(0.6, 1.3),
        });
      }

      for (let i = 0; i < 280; i += 1) {
        const t = (i / 280) * TAU;
        const p = heartPoint(t, scale * 1.02);
        targets.push({
          x: centerX + p.x,
          y: centerY + p.y,
          phase: random(0, TAU),
          layer: random(1.1, 1.55),
        });
      }

      return targets;
    }

    function rebuildScene() {
      heartTargets = buildHeartTargets();
      heartParticles.length = 0;
      stars.length = 0;
      comets.length = 0;
      sparks.length = 0;

      for (let i = 0; i < heartTargets.length; i += 1) {
        const target = heartTargets[i];
        heartParticles.push({
          x: random(0, width),
          y: random(0, height),
          vx: random(-0.5, 0.5),
          vy: random(-0.5, 0.5),
          tx: target.x,
          ty: target.y,
          phase: target.phase,
          layer: target.layer,
          size: random(0.8, 2.2) * target.layer,
          hue: random(322, 350),
          alpha: random(0.55, 1),
        });
      }

      const starCount = Math.floor((width * height) / 5200);
      for (let i = 0; i < starCount; i += 1) {
        stars.push({
          x: random(0, width),
          y: random(0, height),
          z: random(0.18, 1),
          size: random(0.35, 1.55),
          twinkle: random(0, TAU),
          drift: random(0.08, 0.38),
        });
      }

      for (let i = 0; i < 5; i += 1) {
        resetComet({ fresh: true });
      }
    }

    function resetComet(options = {}) {
      const startY = random(height * -0.15, height * 0.82);
      const comet = {
        x: random(-width * 0.5, width * 0.25),
        y: startY,
        vx: random(4.2, 8.5),
        vy: random(1.2, 3.1),
        life: random(0.5, 1),
        delay: options.fresh ? random(0, 9) : random(5, 18),
        length: random(120, 240),
      };
      comets.push(comet);
    }

    function addSpark(x, y, amount) {
      for (let i = 0; i < amount; i += 1) {
        const angle = random(0, TAU);
        const speed = random(0.5, 3.4);
        sparks.push({
          x,
          y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: random(0.45, 1),
          maxLife: random(0.45, 1),
          size: random(0.8, 2.4),
        });
      }
    }

    function drawBackground(time) {
      const bg = ctx.createLinearGradient(0, 0, 0, height);
      bg.addColorStop(0, "#02030b");
      bg.addColorStop(0.48, "#060719");
      bg.addColorStop(1, "#010208");
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      ctx.save();
      ctx.globalCompositeOperation = "lighter";
      for (const star of stars) {
        star.y += star.drift * star.z;
        if (star.y > height + 8) {
          star.y = -8;
          star.x = random(0, width);
        }

        const shimmer = 0.45 + Math.sin(time * 0.0018 + star.twinkle) * 0.35;
        ctx.globalAlpha = clamp((0.2 + star.z * 0.8) * shimmer, 0.08, 0.9);
        ctx.fillStyle = star.z > 0.72 ? "#eafcff" : "#9bb6ff";
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.size * star.z, 0, TAU);
        ctx.fill();
      }
      ctx.restore();
    }

    function drawComets(dt) {
      ctx.save();
      ctx.globalCompositeOperation = "lighter";
      for (let i = comets.length - 1; i >= 0; i -= 1) {
        const comet = comets[i];
        comet.delay -= dt;
        if (comet.delay > 0) continue;

        comet.x += comet.vx * dt * 60;
        comet.y += comet.vy * dt * 60;
        comet.life -= dt * 0.035;

        const angle = Math.atan2(comet.vy, comet.vx);
        const tailX = comet.x - Math.cos(angle) * comet.length;
        const tailY = comet.y - Math.sin(angle) * comet.length;
        const gradient = ctx.createLinearGradient(comet.x, comet.y, tailX, tailY);
        gradient.addColorStop(0, "rgba(126, 247, 255, 0.8)");
        gradient.addColorStop(0.45, "rgba(255, 71, 161, 0.28)");
        gradient.addColorStop(1, "rgba(255, 71, 161, 0)");

        ctx.strokeStyle = gradient;
        ctx.lineWidth = 1.8;
        ctx.beginPath();
        ctx.moveTo(comet.x, comet.y);
        ctx.lineTo(tailX, tailY);
        ctx.stroke();

        ctx.fillStyle = "rgba(255,255,255,0.9)";
        ctx.beginPath();
        ctx.arc(comet.x, comet.y, 1.7, 0, TAU);
        ctx.fill();

        if (comet.x > width + comet.length || comet.y > height + comet.length || comet.life <= 0) {
          comets.splice(i, 1);
          resetComet();
        }
      }
      ctx.restore();
    }

    function drawHud(time) {
      const cx = width / 2;
      const cy = height / 2 + Math.min(height * 0.045, 34);
      const base = Math.min(width, height) * 0.29;
      const pulse = Math.sin(time * 0.002) * 8;

      ctx.save();
      ctx.translate(cx, cy);
      ctx.globalCompositeOperation = "lighter";

      for (let i = 0; i < 3; i += 1) {
        const radius = base + i * 24 + pulse;
        ctx.strokeStyle = i % 2 === 0 ? "rgba(101,247,255,0.20)" : "rgba(255,63,157,0.18)";
        ctx.lineWidth = 1;
        ctx.setLineDash([18 + i * 8, 14 + i * 4]);
        ctx.lineDashOffset = time * (i % 2 === 0 ? -0.045 : 0.035);
        ctx.beginPath();
        ctx.arc(0, 0, radius, 0, TAU);
        ctx.stroke();
      }

      ctx.setLineDash([]);
      for (let i = 0; i < 32; i += 1) {
        const angle = (i / 32) * TAU + time * 0.0004;
        const inner = base + 48;
        const outer = inner + (i % 4 === 0 ? 28 : 12);
        ctx.strokeStyle = i % 4 === 0 ? "rgba(255,255,255,0.24)" : "rgba(101,247,255,0.18)";
        ctx.beginPath();
        ctx.moveTo(Math.cos(angle) * inner, Math.sin(angle) * inner);
        ctx.lineTo(Math.cos(angle) * outer, Math.sin(angle) * outer);
        ctx.stroke();
      }
      ctx.restore();
    }

    function drawHeart(time, dt) {
      ctx.save();
      ctx.globalCompositeOperation = "lighter";

      const influence = pointer.active ? 1 : 0;
      for (const particle of heartParticles) {
        const wave = Math.sin(time * 0.0028 + particle.phase) * 8 * particle.layer;
        const targetX = particle.tx + Math.cos(particle.phase) * wave;
        const targetY = particle.ty + Math.sin(particle.phase * 1.7) * wave * 0.55;

        let pushX = 0;
        let pushY = 0;
        if (influence) {
          const dx = particle.x - pointer.x;
          const dy = particle.y - pointer.y;
          const distSq = dx * dx + dy * dy;
          const radius = 190;
          if (distSq < radius * radius) {
            const dist = Math.sqrt(distSq) || 1;
            const power = (1 - dist / radius) * 5.6;
            pushX = (dx / dist) * power;
            pushY = (dy / dist) * power;
          }
        }

        particle.vx += (targetX - particle.x) * 0.018 + pushX;
        particle.vy += (targetY - particle.y) * 0.018 + pushY;
        particle.vx *= 0.83;
        particle.vy *= 0.83;
        particle.x += particle.vx * dt * 60;
        particle.y += particle.vy * dt * 60;

        const glow = 0.55 + Math.sin(time * 0.004 + particle.phase) * 0.35;
        ctx.globalAlpha = particle.alpha * glow;
        ctx.fillStyle = `hsl(${particle.hue}, 100%, ${64 + glow * 20}%)`;
        ctx.shadowColor = "rgba(255, 63, 157, 0.85)";
        ctx.shadowBlur = 14;
        ctx.beginPath();
        ctx.arc(particle.x, particle.y, particle.size, 0, TAU);
        ctx.fill();
      }

      ctx.restore();

      ctx.save();
      ctx.globalCompositeOperation = "lighter";
      ctx.shadowColor = "rgba(255, 63, 157, 0.95)";
      ctx.shadowBlur = 34;
      ctx.strokeStyle = "rgba(255, 106, 190, 0.32)";
      ctx.lineWidth = Math.max(1.5, Math.min(width, height) * 0.003);
      ctx.beginPath();
      const scale = Math.min(width, height) / 46 * 1.04;
      const cx = width / 2;
      const cy = height / 2 + Math.min(height * 0.045, 34);
      for (let i = 0; i <= 240; i += 1) {
        const p = heartPoint((i / 240) * TAU, scale);
        if (i === 0) ctx.moveTo(cx + p.x, cy + p.y);
        else ctx.lineTo(cx + p.x, cy + p.y);
      }
      ctx.closePath();
      ctx.stroke();
      ctx.restore();
    }

    function drawSparks(dt) {
      ctx.save();
      ctx.globalCompositeOperation = "lighter";
      for (let i = sparks.length - 1; i >= 0; i -= 1) {
        const spark = sparks[i];
        spark.life -= dt;
        spark.x += spark.vx * dt * 60;
        spark.y += spark.vy * dt * 60;
        spark.vx *= 0.98;
        spark.vy *= 0.98;

        const alpha = clamp(spark.life / spark.maxLife, 0, 1);
        ctx.globalAlpha = alpha;
        ctx.fillStyle = Math.random() > 0.5 ? "#65f7ff" : "#ff6bb7";
        ctx.shadowColor = ctx.fillStyle;
        ctx.shadowBlur = 18;
        ctx.beginPath();
        ctx.arc(spark.x, spark.y, spark.size * alpha, 0, TAU);
        ctx.fill();

        if (spark.life <= 0) sparks.splice(i, 1);
      }
      ctx.restore();
    }

    function animate(now) {
      const dt = Math.min((now - lastTime) / 1000, 0.033);
      lastTime = now;

      drawBackground(now);
      drawComets(dt);
      drawHud(now);
      drawHeart(now, dt);
      drawSparks(dt);

      requestAnimationFrame(animate);
    }

    window.addEventListener("resize", resize);
    window.addEventListener("pointermove", (event) => {
      pointer.x = event.clientX;
      pointer.y = event.clientY;
      pointer.active = true;
    });
    window.addEventListener("pointerleave", () => {
      pointer.active = false;
    });
    window.addEventListener("pointerdown", (event) => {
      addSpark(event.clientX, event.clientY, 48);
    });

    resize();
    requestAnimationFrame(animate);
  </script>
</body>
</html>
